#!/bin/bash
# Pre-commit hook for Pintuotuo project
# Runs code quality checks before committing

set -e

echo "🔍 Running pre-commit checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

BACKEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "backend/.*\.go$" || true)
FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "frontend/.*\.\(ts\|tsx\|js\|jsx\)$" || true)

# Check backend code
if [ -n "$BACKEND_FILES" ]; then
    echo -e "${YELLOW}Checking backend code...${NC}"

    cd backend

    # Format check
    if ! go fmt ./...; then
        echo -e "${RED}✗ Go formatting failed${NC}"
        exit 1
    fi

    # Vet check
    if ! go vet ./...; then
        echo -e "${RED}✗ Go vet failed${NC}"
        exit 1
    fi

    echo -e "${GREEN}✓ Backend checks passed${NC}"
    cd ..
fi

# Check frontend code
if [ -n "$FRONTEND_FILES" ]; then
    echo -e "${YELLOW}Checking frontend code...${NC}"

    cd frontend

    # Lint check
    if ! npm run lint --silent; then
        echo -e "${RED}✗ ESLint failed${NC}"
        exit 1
    fi

    # TypeScript check
    if ! npm run type-check --silent; then
        echo -e "${RED}✗ TypeScript type checking failed${NC}"
        exit 1
    fi

    echo -e "${GREEN}✓ Frontend checks passed${NC}"
    cd ..
fi

echo -e "${GREEN}✅ All pre-commit checks passed${NC}"
exit 0
