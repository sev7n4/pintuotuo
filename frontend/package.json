    "vite": "^4.5.0",
    "typescript": "^5.2.0",
    "prettier": "^3.1.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.4",
