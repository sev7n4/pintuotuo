# Database
DB_PASSWORD=your_secure_db_password_here

# JWT
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key

# Frontend
VITE_API_URL=http://localhost:8080/api/v1

# 权益与计价：strict 时 API 代理仅允许已通过已履约订单或有效订阅覆盖的 (provider, model)，并按绑定价目快照扣费；默认 off 兼容历史行为
# ENTITLEMENT_ENFORCEMENT=off
# ENTITLEMENT_ENFORCEMENT=strict

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password

# Payment (Optional)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# Email (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# SMS / 手机号验证码（可选；开发可设 MOCK_SMS=true，验证码固定为 123456）
MOCK_SMS=
SMS_PROVIDER=

# Auth 无感注册（邮箱魔法链接 + 手机验证码）
AUTH_MAGIC_LINK=
EMAIL_MAGIC_MOCK=
PUBLIC_API_BASE_URL=
SMTP_FROM=

# --- 生产/联调：仅 Mock 魔法链接（不发真实邮件；API 会返回 debug_link）---
# 条件：AUTH_MAGIC_LINK=true 且 EMAIL_MAGIC_MOCK=true；且不要配齐 SMTP_HOST/SMTP_PORT/SMTP_FROM，
#       否则会走真实 SMTP，响应里不再带 debug_link。
# AUTH_MAGIC_LINK=true
# EMAIL_MAGIC_MOCK=true
# 验证链接域名：优先 PUBLIC_API_BASE_URL（填浏览器可访问的 API 根，如 https://example.com）
# 未设置时则用 FRONTEND_URL 拼 https://站点/api/v1/...（需 Nginx 把 /api 反代到后端）
# PUBLIC_API_BASE_URL=https://你的域名
# FRONTEND_URL=https://你的前端站点

# OAuth（开放平台 / GitHub：start + callback；回调成功后重定向到 FRONTEND_URL/login?token=...）
# 后端需公网 HTTPS 的 redirect_uri，与微信/GitHub 控制台配置完全一致
# FRONTEND_URL=http://localhost:5173
# WECHAT_OPEN_APP_ID=
# WECHAT_OPEN_APP_SECRET=
# WECHAT_OAUTH_REDIRECT_URI=https://你的域名/api/v1/users/oauth/wechat/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=https://你的域名/api/v1/users/oauth/github/callback
#
# 若部署在大陆机房且直连 github.com 换 token 超时（oauth_error=github_token_network），
# 请复制仓库内 docker-compose.proxy.override.yml.example 为 docker-compose.proxy.override.yml，按需填写代理后：
# docker compose -f docker-compose.prod.yml -f docker-compose.proxy.override.yml up -d --force-recreate backend
# 不要在 .env 里留空 HTTPS_PROXY=（空值会进容器并可能破坏直连）。

# --- 商户邀请注册 / 运营安全 ---
# MERCHANT_REGISTER_MODE=open | invite_only | hidden（默认 invite_only：须有效邀请码方可注册商户）
# ADMIN_MFA_REQUIRED=true 时，已启用 MFA 的运营账号登录须提交 totp_code
# ADMIN_ALLOWED_CIDRS=203.0.113.0/24,192.168.0.0/16
# MFA_TOTP_ISSUER=Pintuotuo
# 管理端生成邀请链接时的前端根地址（/register?invite=...）
# PUBLIC_APP_BASE_URL=https://你的前端域名
# FRONTEND_ORIGIN=https://你的前端域名

# 前端构建时可覆盖默认（仍以 /users/auth/capabilities 为准）
# VITE_MERCHANT_REGISTER_MODE=invite_only

# --- LLM 聚合网关（仅 LiteLLM）---
#
# === 与本项目后端的配合（docker-compose.prod.yml 会读根目录 .env）===
# LLM_GATEWAY_ACTIVE：none=不调聚合网关；litellm 时把 OpenAI 格式出站改到 LiteLLM 的 /v1。
# LLM_GATEWAY_LITELLM_URL：Compose 内网默认即可，一般不改。
# LITELLM_MASTER_KEY：与 LiteLLM 容器环境变量同名、同值；后端在 LLM_GATEWAY_ACTIVE=litellm 时用作
#   Authorization Bearer（平台 Key → 网关）。须为足够长的随机串，并与 LiteLLM 容器配置一致。
#
# 选项: none | litellm
# LLM_GATEWAY_ACTIVE=none
# LLM_GATEWAY_LITELLM_URL=http://litellm:4000
#
# 后端出站鉴权（与 docker-compose.prod.yml backend 注入一致）：
# - 设 LITELLM_MASTER_KEY：走「平台 Key → 网关」
# - 不配则 OpenAI 格式请求仍用商户库内解密的 Key 作为 Bearer（BYOK）
# LITELLM_MASTER_KEY=
#
# === LiteLLM 容器（可选：为网关预置上游厂商 Key，便于 /v1/models 与 chat 立刻可用）===
# 与 LITELLM_MASTER_KEY 相同变量名会注入 litellm 服务：用于客户端调 LiteLLM 时的鉴权（master key）。
# 模型路由见 deploy/litellm/litellm_proxy_config.yaml（model_list），Key 仍只填在 .env，勿写入 yaml。
# 下列为 LiteLLM 识别的常见上游 env，按实际要接的厂商填写（可只填一家做冒烟）：
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MOONSHOT_API_KEY=
# 国内 Moonshot：可选 MOONSHOT_API_BASE=https://api.moonshot.cn/v1（默认 LiteLLM 为 api.moonshot.ai）
# MOONSHOT_API_BASE=
# MiniMax（LiteLLM 前缀 minimax/；见 deploy/litellm/litellm_proxy_config.yaml）
# MINIMAX_API_KEY=
# 国内 MiniMax：可选覆盖 Base，例如 MINIMAX_API_BASE=https://api.minimax.chat/v1
# MINIMAX_API_BASE=
# P1 扩展（与 deploy/litellm/litellm_proxy_config.yaml 中 P1 条目对应）：
# GOOGLE_API_KEY=          # Google AI / Gemini
# DEEPSEEK_API_KEY=
# ZAI_API_KEY=             # 智谱 Z.AI（GLM，LiteLLM 前缀 zai/）
# DASHSCOPE_API_KEY=       # 阿里云通义千问（dashscope/）
#
# Langfuse（灰度）
# LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# --- Prompt 回归（与本机 bash scripts/run_prompt_evals.sh、GitHub Actions secrets 同名）---
# 仓库 Settings → Secrets and variables → Actions 配置后，PR 触发的 Prompt Regression 才会实际跑评测。
# PROMPTFOO_BASE_URL=https://兼容-OpenAI-的网关根地址
# PROMPTFOO_API_KEY=
# PROMPTFOO_MODEL=
