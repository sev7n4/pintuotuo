# Backend Configuration
PORT=8080
GIN_MODE=debug

# Database Configuration
DATABASE_URL=postgresql://pintuotuo:dev_password_123@localhost:5432/pintuotuo_db?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# JWT Configuration
JWT_SECRET=pintuotuo-secret-key-dev
JWT_EXPIRATION=24h

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BROKERS=localhost:29092
KAFKA_VERSION=7.5.0

# API Configuration
API_BASE_URL=http://localhost:8080/api/v1

# Logging
LOG_LEVEL=debug

# Alipay Configuration (for payment processing)
ALIPAY_APP_ID=
ALIPAY_MERCHANT_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# WeChat Configuration (for payment processing)
WECHAT_APP_ID=
WECHAT_MERCHANT_ID=
WECHAT_API_KEY=

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Configuration (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Feature Flags
ENABLE_MOCK_PAYMENTS=true
ENABLE_EMAIL_NOTIFICATIONS=false
