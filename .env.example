# Database
DB_PASSWORD=your_secure_db_password_here

# JWT
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key

# Frontend
VITE_API_URL=http://localhost:8080/api/v1

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password

# Payment (Optional)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# Email (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# SMS / 手机号验证码（可选；开发可设 MOCK_SMS=true，验证码固定为 123456）
MOCK_SMS=
SMS_PROVIDER=

# OAuth（开放平台 / GitHub：start + callback；回调成功后重定向到 FRONTEND_URL/login?token=...）
# 后端需公网 HTTPS 的 redirect_uri，与微信/GitHub 控制台配置完全一致
# FRONTEND_URL=http://localhost:5173
# WECHAT_OPEN_APP_ID=
# WECHAT_OPEN_APP_SECRET=
# WECHAT_OAUTH_REDIRECT_URI=https://你的域名/api/v1/users/oauth/wechat/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=https://你的域名/api/v1/users/oauth/github/callback
#
# 若部署在大陆机房，GitHub OAuth 换 token 需访问 https://github.com/login/oauth/access_token（与 api.github.com 不同），
# 常出现连接超时 → 回调报错 oauth_error=github_token_network。请为后端配置可访问 github.com 的 HTTPS 出口，例如：
# HTTPS_PROXY=http://host.docker.internal:7890
# NO_PROXY=localhost,127.0.0.1,postgres,redis,backend,frontend,pintuotuo-postgres,pintuotuo-redis
# （代理跑在宿主机时配合 docker-compose.prod.yml 中 host.docker.internal；或填境外 HTTP 代理地址）
