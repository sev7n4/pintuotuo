{
  "id": null,
  "uid": "ptt-llm-overview",
  "title": "LLM Gateway Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP RPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "5xx Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
          "legendFormat": "5xx-rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "P95 Latency by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "LiteLLM target up",
      "description": "Prometheus job litellm:4000；0 表示网关不可达或未启动 llm-gateway profile",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "up{job=\"litellm\"}",
          "legendFormat": "litellm",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Backend target up",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "up{job=\"pintuotuo-backend\"}",
          "legendFormat": "backend",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "annotations": { "list": [] }
}
