# 海外 LiteLLM 单节点 — 服务器本地 /opt/pintuotuo-litellm/.env
# 复制：cp deploy/litellm/.env.example /opt/pintuotuo-litellm/.env 后编辑
# 勿提交真实 .env 到 Git。LITELLM_MASTER_KEY 须与大陆 backend 完全一致。

# === 必填 ===
LITELLM_MASTER_KEY=sk-your-litellm-master-key

# === 可选 ===
LITELLM_IMAGE_TAG=v1.83.3-stable

# 海外单机通常不需要 OTLP（大陆内网 Tempo 才用）
# LITELLM_OTEL_SERVICE_NAME=litellm-proxy-overseas
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
